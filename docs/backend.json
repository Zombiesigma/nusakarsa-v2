{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["admin", "penulis", "pembaca"]
        },
        "followers": { "type": "array", "items": { "type": "string" } },
        "following": { "type": "array", "items": { "type": "string" } },
        "bookmarks": {
          "type": "array",
          "description": "An array of book IDs that the user has bookmarked.",
          "items": { "type": "string" }
        },
        "phoneNumber": { "type": "string" },
        "domicile": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName", "role"]
    },
    "Book": {
      "title": "Book",
      "description": "Represents a book in the library.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoUrl": { "type": "string", "format": "uri" },
        "type": { "type": "string", "enum": ["book", "poem"] },
        "genre": { "type": "string" },
        "synopsis": { "type": "string" },
        "coverUrl": { "type": "string", "format": "uri" },
        "status": { "type": "string", "enum": ["draft", "pending_review", "published"] },
        "visibility": { "type": "string", "enum": ["public", "followers_only"] },
        "isCompleted": { "type": "boolean" },
        "viewCount": { "type": "number" },
        "favoriteCount": { "type": "number" },
        "chapterCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "collaboratorUids": { "type": "array", "items": { "type": "string" } },
        "fileUrl": { "type": "string", "format": "uri" },
        "playlist": {
          "type": "array",
          "items": { "$ref": "#/entities/MusicTrack" }
        }
      },
      "required": ["title", "authorId", "authorName", "type", "status"]
    },
    "Chapter": {
        "title": "Chapter",
        "description": "Represents a chapter within a book.",
        "type": "object",
        "properties": {
            "title": { "type": "string" },
            "content": { "type": "string" },
            "order": { "type": "number" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["title", "content", "order"]
    },
    "AuthorRequest": {
        "title": "Author Request",
        "description": "A user's request to become an author.",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "name": { "type": "string" },
            "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
            "phoneNumber": { "type": "string" },
            "domicile": { "type": "string" },
            "portfolio": { "type": "string", "format": "uri" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "name", "status", "phoneNumber", "domicile", "createdAt"]
    },
    "Story": {
        "title": "Story",
        "description": "A short-lived story/moment posted by a user.",
        "type": "object",
        "properties": {
            "authorId": { "type": "string" },
            "authorName": { "type": "string" },
            "authorAvatarUrl": { "type": "string", "format": "uri" },
            "content": { "type": "string" },
            "mediaUrl": { "type": "string", "format": "uri" },
            "mediaType": { "type": "string", "enum": ["image", "video"] },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["authorId", "authorName", "authorAvatarUrl", "createdAt"]
    },
    "Music": {
      "title": "Music",
      "description": "Represents a music track available in the internal library.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "youtubeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "artist", "youtubeId", "createdAt"]
    },
    "MusicTrack": {
      "title": "Music Track",
      "description": "Represents a music track in a book's playlist.",
      "type": "object",
      "properties": {
          "name": { "type": "string" },
          "artist": { "type": "string" },
          "image": { "type": "string", "format": "uri" },
          "id": { "type": "string" },
          "source": { "type": "string", "enum": ["youtube", "internal"] }
      },
      "required": ["name", "artist", "image", "id", "source"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profile information."
    },
    "/books/{bookId}": {
      "schema": { "$ref": "#/entities/Book" },
      "description": "Stores all the books available in the application."
    },
    "/books/{bookId}/chapters/{chapterId}": {
      "schema": { "$ref": "#/entities/Chapter" },
      "description": "Stores the chapters for a specific book."
    },
    "/authorRequests/{requestId}": {
      "schema": { "$ref": "#/entities/AuthorRequest" },
      "description": "Stores requests from users to become authors."
    },
    "/stories/{storyId}": {
      "schema": { "$ref": "#/entities/Story" },
      "description": "Stores user-created stories/moments."
    },
    "/music/{musicId}": {
      "schema": { "$ref": "#/entities/Music" },
      "description": "Stores the internal music library for the app."
    }
  }
}
