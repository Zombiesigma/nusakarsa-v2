{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["admin", "penulis", "pembaca"]
        },
        "followers": { "type": "array", "items": { "type": "string" } },
        "following": { "type": "array", "items": { "type": "string" } },
        "bookmarks": {
          "type": "array",
          "description": "An array of book IDs that the user has bookmarked.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["uid", "email", "displayName", "role"]
    },
    "Book": {
      "title": "Book",
      "description": "Represents a book in the library.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoUrl": { "type": "string", "format": "uri" },
        "type": { "type": "string", "enum": ["book", "screenplay", "poem"] },
        "genre": { "type": "string" },
        "synopsis": { "type": "string" },
        "coverUrl": { "type": "string", "format": "uri" },
        "status": { "type": "string", "enum": ["draft", "pending_review", "published"] },
        "visibility": { "type": "string", "enum": ["public", "followers_only"] },
        "isCompleted": { "type": "boolean" },
        "viewCount": { "type": "number" },
        "favoriteCount": { "type": "number" },
        "chapterCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "collaboratorUids": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "authorId", "authorName", "type", "status"]
    },
    "Chapter": {
        "title": "Chapter",
        "description": "Represents a chapter within a book.",
        "type": "object",
        "properties": {
            "title": { "type": "string" },
            "content": { "type": "string" },
            "order": { "type": "number" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["title", "content", "order"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profile information."
    },
    "/books/{bookId}": {
      "schema": { "$ref": "#/entities/Book" },
      "description": "Stores all the books available in the application."
    },
    "/books/{bookId}/chapters/{chapterId}": {
      "schema": { "$ref": "#/entities/Chapter" },
      "description": "Stores the chapters for a specific book."
    }
  }
}
