rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isWriter(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'penulis';
    }

    function isAdmin(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if true; // Public profiles can be read by anyone
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin(request.auth.uid));
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /books/{bookId} {
      allow read: if true;
      
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid
                    && isWriter(request.auth.uid);
                    
      allow update: if request.auth != null && (
        (resource.data.authorId == request.auth.uid && isWriter(request.auth.uid))
        || (request.auth.uid in resource.data.collaboratorUids)
        || isAdmin(request.auth.uid)
      );

      allow delete: if request.auth != null && (
        (resource.data.authorId == request.auth.uid && isWriter(request.auth.uid))
        || isAdmin(request.auth.uid)
      );
      
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if request.auth != null && (
          get(/databases/$(database)/documents/books/$(bookId)).data.authorId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/books/$(bookId)).data.collaboratorUids ||
          isAdmin(request.auth.uid)
        );
      }
    }
    
    match /authorRequests/{requestId} {
      allow read, list, update: if request.auth != null && isAdmin(request.auth.uid);
      allow create: if request.auth != null;
    }
    
    match /stories/{storyId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null && (isAdmin(request.auth.uid) || resource.data.authorId == request.auth.uid);
    }

    match /collaborationInvitations/{invitationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.collaboratorId;
      allow create: if request.auth != null && isWriter(request.auth.uid);
    }

    match /music/{musicId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }
  }
}
