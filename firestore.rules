rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isWriter(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'penulis';
    }

    // Users can only read and write their own data.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Books can be read by anyone.
    // Authenticated users with the 'penulis' role can create new books.
    // Only the owner with the 'penulis' role can update or delete their book.
    match /books/{bookId} {
      allow read: if true;
      
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && isWriter(request.auth.uid);
                    
      allow update, delete: if request.auth != null 
                            && resource.data.ownerId == request.auth.uid
                            && isWriter(request.auth.uid);
    }
  }
}
