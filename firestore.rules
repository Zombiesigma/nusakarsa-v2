rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function canEditBook(bookId) {
      let bookData = get(/databases/$(database)/documents/books/$(bookId)).data;
      return isAuthenticated() && (
        bookData.authorId == request.auth.uid || 
        (request.auth.uid in (bookData.collaboratorUids || [])) || 
        isAdmin()
      );
    }

    match /users/{userId} {
      allow read, list: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
      
      match /notifications/{notifId} {
        allow read, list, update, delete: if isOwner(userId) || isAdmin();
        allow create: if isAuthenticated(); 
      }

      match /following/{followId} {
        allow read, list, write: if isOwner(userId);
      }

      match /followers/{followerId} {
        allow read, list: if isAuthenticated();
        allow write: if isAuthenticated();
      }

      match /favorites/{favId} {
        allow read, list, write: if isOwner(userId);
      }
    }

    match /collaborationInvitations/{inviteId} {
      allow read, list: if isAuthenticated() && (
        request.auth.uid == resource.data.collaboratorId || 
        request.auth.uid == resource.data.ownerId
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.collaboratorId == request.auth.uid);
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || resource.data.collaboratorId == request.auth.uid);
    }
    
    match /books/{bookId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid || 
        (request.auth.uid in (resource.data.collaboratorUids || [])) || 
        isAdmin()
      );
      
      match /chapters/{chapterId} {
        allow read, list: if isAuthenticated();
        allow write: if canEditBook(bookId);
      }

      match /shotList/{shotId} {
        allow read, list: if isAuthenticated();
        allow write: if canEditBook(bookId);
      }

      match /comments/{commentId} {
        allow read, list: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

        match /likes/{likeId} {
          allow read, list, write: if isAuthenticated();
        }
        match /replies/{replyId} {
          allow read, list, write: if isAuthenticated();
        }
      }
    }

    match /authorRequests/{requestId} {
      allow read, list: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /music/{musicId} {
      allow read, list: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}